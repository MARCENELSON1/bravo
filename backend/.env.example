# === BRAVO backend — environment template (copy to .env; .env is gitignored) ===
ENV=dev

# Database — app role (NON-superuser; RLS is enforced for this role)
DATABASE_URL=postgresql+asyncpg://bravo_app:bravo_app@localhost:5432/bravo_dev
# Admin/superuser URL used ONLY by Alembic to create the app role, tables and RLS policies.
# Locally with Homebrew Postgres the superuser is usually your OS user (e.g. marce) or "postgres".
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/bravo_dev
# Password the migration assigns to the bravo_app role (prod: a strong secret;
# the app's DATABASE_URL connects as bravo_app with this password). Quote/backslash-free.
APP_ROLE_PASSWORD=bravo_app

# CORS — comma-separated SPA origins for a split-domain deploy (empty in dev).
# When set, pair with COOKIE_SAMESITE=none so the refresh cookie works cross-site.
CORS_ORIGINS=
# COOKIE_SAMESITE=lax        # set to "none" when the SPA and API are on different domains

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# One-time tokens
RESET_TOKEN_TTL_MIN=30
VERIFICATION_TOKEN_TTL_HOURS=24
INVITATION_TOKEN_TTL_HOURS=72

# Email — "console" prints the link to stdout (dev); "smtp" sends via aiosmtplib
EMAIL_TRANSPORT=console
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@bravo.app
SMTP_USE_TLS=false

APP_BASE_URL=http://localhost:5173

# Login throttling
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Payments gateway — "manual" (default) confirms cash/card/transfer immediately.
# "mercadopago" creates a Checkout Pro link/QR for online charges (method
# MERCADOPAGO/QR) and confirms them via the webhook below. Use TEST-* credentials
# for the sandbox. NEVER commit real tokens — keep them in .env only.
PAYMENT_GATEWAY=manual
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
# Public URL MercadoPago posts notifications to (e.g. an ngrok tunnel in dev):
#   https://<your-tunnel>/api/v1/webhooks/mercadopago
MP_NOTIFICATION_URL=
